{
	"name": "open-yaske",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"prebuild": "node tools/update-project-name.cjs && node tools/generate-assets.cjs",
		"predev": "node tools/update-project-name.cjs",
		"dev": "concurrently -k -n vite,mock-cdn -c blue,magenta \"pnpm dev:vite\" \"pnpm dev:mock-cdn\"",
		"dev:vite": "PUBLIC_DATA_CDN_BASE=/cdn vite dev",
		"dev:mock-cdn": "tsx tools/mock-cdn/server.ts",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"assets:generate": "node tools/generate-assets.cjs"
	},
	"devDependencies": {
		"@capacitor/android": "^8.4.1",
		"@capacitor/assets": "^3.0.5",
		"@capacitor/ios": "^8.4.1",
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/js": "^10.0.1",
		"@hono/node-server": "^2.0.6",
		"@inlang/paraglide-js": "^2.18.2",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-a11y": "^10.4.6",
		"@storybook/addon-docs": "^10.4.6",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/sveltekit": "^10.4.6",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.6",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/katex": "^0.16.8",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.8",
		"concurrently": "^10.0.3",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.4.6",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"hono": "^4.12.26",
		"mdsvex": "^0.12.7",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"storybook": "^10.4.6",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@capacitor/browser": "^8.0.3",
		"@capacitor/cli": "^8.4.1",
		"@capacitor/core": "^8.4.1",
		"@capacitor/local-notifications": "^8.2.0",
		"@capgo/capacitor-document-scanner": "^8.3.33",
		"@lucide/svelte": "^1.21.0",
		"date-holidays": "^3.30.2",
		"dompurify": "^3.4.11",
		"idb-keyval": "^6.2.5",
		"jspdf": "^4.2.1",
		"katex": "^0.17.0",
		"marked": "^18.0.5",
		"mermaid": "^11.16.0",
		"remotestoragejs": "2.0.0-beta.9"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"sharp",
			"@tailwindcss/oxide",
			"esbuild"
		]
	}
}
